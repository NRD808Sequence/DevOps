observability: {
  label: "Observability"
  style.fill: "#0d1f1f"
  style.stroke: "#39d353"

  cw: {
    label: "CloudWatch\nDashboard: vandelay-dashboard01\nAlarm: vandelay-db-connection-failure\nAlarm: vandelay-alb-5xx-alarm\nLog: /aws/ec2/vandelay-rds-app\nLog: aws-waf-logs-vandelay-webacl"
    style.fill: "#1a3d3d"
    style.font-color: "#c9d1d9"
  }

  ct: {
    label: "CloudTrail\nvandelay-trail\nS3: vandelay-cloudtrail-212809501772"
