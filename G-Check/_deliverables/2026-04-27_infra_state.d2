    style.font-color: "#c9d1d9"
  }

  lambda: {
    label: "Incident Reporter Lambda\nvandelay-incident-reporter\nBedrock + SNS integration\nS3: vandelay-incident-reports-212809501772"
    style.fill: "#1a3d3d"
    style.font-color: "#c9d1d9"
  }
}

# ── Storage ───────────────────────────────────────────────────────────────────
storage: {
  label: "S3 Storage"
  style.fill: "#1f1a0d"
  style.stroke: "#e3b341"

  tf_state: {
    label: "TF State Bucket\nclass7-armagaggeon-tf-bucket\nVersioning + SSE-KMS\nNEVER DESTROY"
    shape: cylinder
    style.fill: "#4d3a00"
    style.stroke: "#e3b341"
    style.font-color: "#c9d1d9"
  }

  deliverables: {
    label: "Deliverables Bucket\nvandelay-deliverables-212809501772\nPublic static website\nindex.html gallery"
    shape: cylinder
    style.fill: "#3d2e00"
    style.font-color: "#c9d1d9"
  }

  alb_logs: {
    label: "ALB Logs\nvandelay-alb-logs-212809501772\nVersioning enabled"
    shape: cylinder
    style.fill: "#3d2e00"
    style.font-color: "#c9d1d9"
  }

  cloudtrail_s3: {
    label: "CloudTrail Logs\nvandelay-cloudtrail-212809501772"
    shape: cylinder
    style.fill: "#3d2e00"
    style.font-color: "#c9d1d9"
  }
}

# ── Connections ───────────────────────────────────────────────────────────────
cicd.github -> cdn.route53: "webhook push\ngithub-creds PAT"
cdn.route53 -> cdn.cf: "app.keepuneat.click\nA alias"
cdn.route53 -> vpc.public.alb_jenkins: "jenkins.keepuneat.click\nA alias"
cdn.cf -> cdn.waf_cf: inspect
cdn.waf_cf -> vpc.public.alb_app: "origin request\nX-Origin-Verify header"
cdn.acm -> cdn.cf: "TLS"
cdn.acm -> vpc.public.alb_jenkins: "TLS"
vpc.public.alb_app -> vpc.public.waf_regional: inspect
vpc.public.waf_regional -> vpc.private.ec2_app: "HTTP 8080"
vpc.public.alb_jenkins -> vpc.private.jenkins: "HTTP 8080"
vpc.public.igw -> vpc.public.nat: egress
vpc.public.nat -> vpc.private.jenkins: NAT
vpc.private.jenkins -> vpc.private.ebs: "data volume"
vpc.private.jenkins -> vpc.private.rds: "MySQL 3306"
vpc.private.ec2_app -> vpc.private.rds: "MySQL 3306"
vpc.private.jenkins -> vpc.private.vpce: "AWS API calls"
vpc.private.vpce -> security.sm: "GetSecretValue"
vpc.private.vpce -> security.ssm: "GetParameter"
vpc.private.jenkins -> storage.tf_state: "TF backend\nS3 + DynamoDB lock"
vpc.private.jenkins -> observability.sns: "pipeline notify"
observability.sns -> observability.lambda: "db incident trigger"
observability.lambda -> storage.deliverables: "incident report"
vpc.private.ec2_app -> observability.cw: "app logs"
vpc.public.alb_app -> storage.alb_logs: "access logs"
