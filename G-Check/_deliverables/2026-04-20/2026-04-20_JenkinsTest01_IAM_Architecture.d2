  style.stroke-dash: 5
}
current_policy -> aws_full: "Unrestricted access\n(exceeds pipeline scope)" {
  style.stroke: "#dc2626"
  style.stroke-width: 2
  style.stroke-dash: 3
}

# Pike derivation chain
jenkins.p2 -> pike: "Stage: Pike Scan\nruns every build\narchives pike-policy.json" {
  style.stroke: "#7c3aed"
  style.stroke-width: 2
}
pike -> proposed_policy: "Generates minimum\nS3 + DynamoDB actions\nfrom terraform source" {
  style.stroke: "#7c3aed"
  style.stroke-width: 2
}

# Proposed (fixed) path
iam_user -> proposed_policy: "PROPOSED attachment\n(after remediation)" {
