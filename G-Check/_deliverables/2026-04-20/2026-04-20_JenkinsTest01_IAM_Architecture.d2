direction: right

# ── ZONE 1: Jenkins EC2 ───────────────────────────────────────

jenkins: "Jenkins EC2  (i-0ea63c7bf813933c8  |  t3.medium  |  us-east-1a)" {
  style.fill: "#0f2942"
  style.font-color: "#e2e8f0"
  style.stroke: "#2563eb"
  style.stroke-width: 2

  p1: "Pipeline 1\nvandelay-lab2-pipeline\n\nTrigger: GitHub Push Webhook\nJenkinsfile: G-Check/Jenkinsfile\nCredential: NONE stored\n(uses EC2 Instance Profile)" {
    style.fill: "#1e4976"
    style.font-color: white
    style.stroke: "#2563eb"
  }

  p2: "Pipeline 2\njenkins-s3-test\n\nTrigger: Manual (admin)\nJenkinsfile: jenkins-s3-test/Jenkinsfile\nCredential: JenkinsTest01\n(CLASS REQUIREMENT)" {
    style.fill: "#1e4976"
    style.font-color: white
    style.stroke: "#2563eb"
  }

  creds_store: "Jenkins Credentials Manager\n────────────────────────────\nID: JenkinsTest01\nType: AmazonWebServicesCredentialsBinding\nScope: GLOBAL\n\nInjects at runtime:\n  AWS_ACCESS_KEY_ID\n  AWS_SECRET_ACCESS_KEY\n(never logged — masked in console)" {
    style.fill: "#14532d"
    style.font-color: white
    style.stroke: "#16a34a"
  }
}

# ── ZONE 2: Credential Path 1 — Instance Profile ─────────────

imds: "EC2 Instance Metadata Service\n(IMDSv2  |  http_tokens = required)\n\nSecurity: Blocks SSRF credential theft\n(OWASP A10 — Server-Side Request Forgery)\n\nNo secrets stored anywhere.\nSTS auto-rotates token every ~1 hour." {
  shape: hexagon
  style.fill: "#1e3a5f"
  style.font-color: white
  style.stroke: "#3b82f6"
}

jenkins_role: "IAM Role\nvandelay-jenkins-role\n\nTrust Policy: ec2.amazonaws.com\nInstance Profile: vandelay-jenkins-profile\nAttached to: vandelay_jenkins EC2" {
  shape: rectangle
  style.fill: "#92400e"
  style.font-color: white
  style.stroke: "#d97706"
}

deploy_policy: "VandelayTerraformDeployPolicy\n(inline role policy — 3 statements)\n────────────────────────────────\nSid: TerraformStateS3\n  s3:GetObject | PutObject | DeleteObject\n  s3:ListBucket | GetBucketVersioning\n  Resource: class7-armagaggeon-tf-bucket\n\nSid: TerraformInfra\n  ec2:* | rds:* | iam:* | s3:*\n  elasticloadbalancing:* | wafv2:*\n  route53:* | secretsmanager:*\n  cloudfront:* | lambda:* | ssm:*\n  kms:* | cloudwatch:* | logs:*\n  Resource: * (lab-2 scope)\n\nSid: ServerlessApplicationRepository\n  serverlessrepo:GetApplication\n  serverlessrepo:CreateCloudFormationTemplate\n  serverlessrepo:CreateCloudFormationChangeSet\n  cloudformation:CreateChangeSet + 9 more\n  Resource: *" {
  shape: rectangle
  style.fill: "#b45309"
  style.font-color: white
  style.stroke: "#d97706"
}

# ── ZONE 3: Credential Path 2 — JenkinsTest01 ────────────────

iam_user: "IAM User\nJenkinsTest01\n────────────────────────────────\nARN: arn:aws:iam::212809501772\n      :user/JenkinsTest01\n\nClass Requirement:\nDemonstrate IAM User static credential\nused via AWSCredentialsBinding in a\nJenkins declarative pipeline.\nProves: sts:GetCallerIdentity resolves\nto IAM User (not role / instance profile)" {
  shape: rectangle
  style.fill: "#1f2937"
  style.font-color: white
  style.stroke: "#4b5563"
  style.stroke-width: 2
}

current_policy: "CURRENT — AdministratorAccess\n(AWS Managed Policy)\n────────────────────────────────\nAction:   \"*\"\nResource: \"*\"\nEffect:   Allow\n\nOWASP C3 — A02:2021\nCryptographic / Privilege Failures\n\nBlast radius: full account takeover\nif Access Key is leaked or rotated\nkeys are not revoked promptly." {
  shape: rectangle
  style.fill: "#7f1d1d"
  style.font-color: white
  style.stroke: "#dc2626"
  style.stroke-width: 3
}

# ── ZONE 4: Pike IAM Scanner ──────────────────────────────────

pike: "Pike IAM Scanner\njameswoolfenden/pike\n────────────────────────────────\nRuns INSIDE jenkins-s3-test pipeline\nStage: Pike Scan (build #6 — PASS)\n\nMethod:\n  docker run jameswoolfenden/pike\n    scan -d /tf -o json\n\nOutput: pike-policy.json\n  (archived as build artifact)\n\nLogic: Reads .tf files → maps each\nresource type to its minimum\nIAM actions → outputs JSON policy" {
  shape: diamond
  style.fill: "#4c1d95"
  style.font-color: white
  style.stroke: "#7c3aed"
  style.stroke-width: 2
}

# ── ZONE 5: Proposed Least-Priv Policy ───────────────────────

proposed_policy: "PROPOSED — JenkinsTest01-LeastPriv\n(Customer Managed Policy)\n────────────────────────────────\nSid: STSIdentity\n  sts:GetCallerIdentity\n  Resource: *\n  (Stage 1: Set AWS Credentials)\n\nSid: S3ArtifactBucket\n  s3:PutObject | GetObject | DeleteObject\n  Resource:\n    class7-armagaggeon-tf-bucket\n    /jenkins-artifacts/*\n  (Stage 2: S3 Artifact Test)\n\nSid: S3TerraformBuckets  ← Pike output\n  s3:CreateBucket | DeleteBucket\n  s3:ListBucket | GetBucket* (9 actions)\n  s3:PutBucketTagging | PutObject\n  s3:GetObject | GetObjectAcl\n  s3:DeleteObject | GetReplicationConfiguration\n  Resource: arn:aws:s3:::jenkins-bucket-*\n\nSid: DynamoDBStateLock  ← Pike output\n  dynamodb:GetItem | PutItem\n  dynamodb:DeleteItem | DescribeTable\n  Resource: arn:aws:dynamodb:us-east-1\n    :212809501772:table/terraform-state-lock\n\nNote: Remove AdministratorAccess\nbefore or simultaneously with attaching\nthis policy to JenkinsTest01." {
  shape: rectangle
  style.fill: "#064e3b"
  style.font-color: white
  style.stroke: "#10b981"
  style.stroke-width: 3
}

# ── ZONE 6: AWS Targets ───────────────────────────────────────

aws_full: "AWS Account — Full Lab-2 Stack\n────────────────────────────────\nVPC | EC2 (app + jenkins)\nRDS MySQL | ALB | CloudFront\nWAF v2 | Route53 | ACM\nSecrets Manager | Lambda\nSSM Parameter Store | CloudWatch\nEBS | NAT Gateway | VPC Endpoints\nSAR Stack (rotation lambda)" {
  shape: cylinder
  style.fill: "#c2410c"
  style.font-color: white
  style.stroke: "#ea580c"
}

aws_scoped: "AWS — jenkins-s3-test Scope Only\n────────────────────────────────\nS3: class7-armagaggeon-tf-bucket\n    └─ /jenkins-artifacts/* (artifact test)\n    └─ /terraform/jenkins-s3-test/* (TF state)\n\nS3: jenkins-bucket-* (ephemeral)\n    Created by TF Apply\n    Destroyed by TF Destroy\n    (same pipeline run — no persistence)\n\nDynamoDB: terraform-state-lock\n    TF state locking only" {
  shape: cylinder
  style.fill: "#064e3b"
  style.font-color: white
  style.stroke: "#10b981"
}

# ── CONNECTIONS ───────────────────────────────────────────────

# Pipeline 1 auth chain
jenkins.p1 -> imds: "1. No credentials stored\n   EC2 auto-fetches token\n   from instance metadata" {
  style.stroke: "#3b82f6"
  style.stroke-width: 2
}
imds -> jenkins_role: "2. STS AssumeRole\n   (auto-refresh ~1h)" {
  style.stroke: "#3b82f6"
  style.stroke-width: 2
}
jenkins_role -> deploy_policy: "3. Policy evaluated\n   per API call" {
  style.stroke: "#3b82f6"
}
deploy_policy -> aws_full: "4. Deploys & manages\n   full lab-2 infra" {
  style.stroke: "#3b82f6"
  style.stroke-width: 2
}

# Pipeline 2 auth chain
jenkins.p2 -> jenkins.creds_store: "1. withCredentials([\n   AWSCredentialsBinding\n   credId: 'JenkinsTest01'])" {
  style.stroke: "#f59e0b"
  style.stroke-width: 2
}
jenkins.creds_store -> iam_user: "2. Injects key pair\n   as env vars\n   (masked in logs)" {
  style.stroke: "#f59e0b"
  style.stroke-width: 2
}

