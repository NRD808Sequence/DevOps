###############################################################
# Deliverables S3 Bucket — Public + Terraform-Managed
# Date: 2026-04-22
# Requirement: Bucket is PUBLIC and CREATED VIA TERRAFORM.
#              Objects (screenshots) uploaded via Terraform.
# Author: NRD808Sequence
###############################################################

direction: right

###############################################################
# ZONE 1 — Source: Git Repo
###############################################################

git: "GitHub Repo\nNRD808Sequence / DevOps\n──────────────────────\nG-Check/16-s3-website.tf\nG-Check/_deliverables/**/*.png\n(57 screenshots tracked in git)\n\nPush to main →\ntriggers webhook" {
  shape: rectangle
  style.fill: "#1f2937"
  style.font-color: white
  style.stroke: "#4b5563"
  style.stroke-width: 2
}

###############################################################
# ZONE 2 — Jenkins Pipeline
###############################################################

jenkins: "Jenkins EC2\nvandelay-lab2-pipeline\n──────────────────────\nCredential: EC2 Instance Profile\n(zero stored secrets)\n\nStages:\n  TF Init → TF Validate\n  Pike Scan → TF Plan\n  Approval Gate\n  TF Apply ← uploads objects\n  Smoke Test → Gate Tests" {
  shape: rectangle
  style.fill: "#0f2942"
  style.font-color: "#e2e8f0"
  style.stroke: "#2563eb"
  style.stroke-width: 2
}

###############################################################
# ZONE 3 — Terraform Resources (16-s3-website.tf)
###############################################################

tf: "Terraform — 16-s3-website.tf\n(vandelay-lab2-pipeline TF Apply)" {
  style.fill: "#1a1a2e"
  style.font-color: white
  style.stroke: "#7c3aed"
  style.stroke-width: 2

  r1: "① aws_s3_bucket\nvandelay_deliverables\n──────────────────────\nbucket = vandelay-{name_prefix}\n         -deliverables-{account_id}\n\nCREATED BY TERRAFORM" {
    style.fill: "#312e81"
    style.font-color: white
    style.stroke: "#6366f1"
    style.stroke-width: 2
  }

  r2: "② aws_s3_bucket_public_access_block\n──────────────────────\nblock_public_acls       = false\nblock_public_policy     = false\nignore_public_acls      = false\nrestrict_public_buckets = false\n\nALL BLOCKS REMOVED" {
    style.fill: "#7f1d1d"
    style.font-color: white
    style.stroke: "#dc2626"
    style.stroke-width: 2
  }

  r3: "③ aws_s3_bucket_policy\n──────────────────────\nSid: PublicReadGetObject\nEffect: Allow\nPrincipal: \"*\"\nAction: s3:GetObject\nResource: bucket/*\n\nFULLY PUBLIC READ" {
    style.fill: "#7f1d1d"
    style.font-color: white
    style.stroke: "#dc2626"
    style.stroke-width: 2
  }

  r4: "④ aws_s3_bucket_website_configuration\n──────────────────────\nindex_document: index.html\nerror_document: error.html\n\nSTATIC WEBSITE ENABLED" {
    style.fill: "#14532d"
    style.font-color: white
    style.stroke: "#16a34a"
  }

  r5: "⑤ aws_s3_object (index)\n──────────────────────\nkey: index.html\nsource: website/index.html\ncontent_type: text/html\netag: filemd5(...)\n\n1 HTML file" {
    style.fill: "#14532d"
    style.font-color: white
    style.stroke: "#16a34a"
  }

  r6: "⑥ aws_s3_object (screenshots)\nfor_each = fileset(\n  \"_deliverables\", \"**/*.png\")\n──────────────────────\nkey: deliverables/{path}\nsource: _deliverables/{path}\ncontent_type: image/png\netag: filemd5(...)\n\n57 SCREENSHOTS\nUPLOADED VIA TERRAFORM" {
    style.fill: "#064e3b"
    style.font-color: white
    style.stroke: "#10b981"
    style.stroke-width: 3
  }
}

###############################################################
# ZONE 4 — S3 Bucket (deployed result)
###############################################################

bucket: "S3 Bucket (deployed)\nvandelay-{prefix}-deliverables-{acct}\n──────────────────────\nACCESS: PUBLIC\nHosting: Static Website\nURL: http://{bucket}.s3-website\n     -us-east-1.amazonaws.com\n\nEncryption: AES-256 (default)\nVersioning: via tf-state-hardening.tf" {
  shape: cylinder
  style.fill: "#78350f"
  style.font-color: white
  style.stroke: "#f59e0b"
  style.stroke-width: 2
}

objects: "Objects in Bucket\n──────────────────────\n/index.html\n  ← Terraform managed\n\n/deliverables/\n  2026-04-05/screenshots/*.png  (10)\n  2026-04-07/*.png              (11)\n  2026-04-11/screenshots/*.png  (13)\n  2026-04-13/screenshots/*.png  (10)\n  ─────────────────────────────\n  Total: 57 PNGs\n  All: s3:GetObject = public" {
  shape: rectangle
  style.fill: "#1c1917"
  style.font-color: "#d6d3d1"
  style.stroke: "#f59e0b"
}

###############################################################
# ZONE 5 — Public Access
###############################################################

public: "Public Access\n(Instructor / Class Review)\n──────────────────────\nAny browser, no auth required\n\nGET /index.html → 200 OK\nGET /deliverables/2026-04-13/\n  screenshots/pipeline-build.png\n  → 200 OK (image)\n\nPrincipal: \"*\" in bucket policy\n= unauthenticated public read" {
  shape: rectangle
  style.fill: "#1e3a5f"
  style.font-color: white
  style.stroke: "#3b82f6"
  style.stroke-width: 2
}

###############################################################
# CLASS REQUIREMENT CHECKLIST
###############################################################

reqs: "Class Requirements\n──────────────────────\n✅ Bucket is PUBLIC\n   Principal: \"*\" + PAB all false\n\n✅ Bucket CREATED VIA TERRAFORM\n   aws_s3_bucket.vandelay_deliverables\n   in 16-s3-website.tf\n\n✅ Objects UPLOADED VIA TERRAFORM\n   aws_s3_object.deliverable_screenshots\n   for_each = fileset(\"**/*.png\")\n   57 screenshots via TF Apply\n\n✅ Deployed by JENKINS PIPELINE\n   vandelay-lab2-pipeline\n   EC2 Instance Profile credential" {
  shape: rectangle
  style.fill: "#064e3b"
  style.font-color: white
  style.stroke: "#10b981"
  style.stroke-width: 3
}

###############################################################
# CONNECTIONS
###############################################################

git -> jenkins: "1. GitHub Push\n   webhook triggers\n   pipeline build" {
  style.stroke: "#4b5563"
  style.stroke-width: 2
}

jenkins -> tf: "2. terraform apply\n   (EC2 Instance Profile\n    — no stored creds)" {
  style.stroke: "#2563eb"
  style.stroke-width: 2
}

tf.r1 -> tf.r2: "depends_on" {
  style.stroke: "#6366f1"
}

tf.r2 -> tf.r3: "depends_on\n(PAB must be clear\nbefore policy applies)" {
  style.stroke: "#dc2626"
}

tf.r3 -> tf.r4: "" {
  style.stroke: "#6366f1"
}

tf.r4 -> tf.r5: "depends_on\nbucket_policy" {
  style.stroke: "#16a34a"
}

tf.r5 -> tf.r6: "same depends_on" {
  style.stroke: "#10b981"
}

tf -> bucket: "3. Creates bucket\n   + applies policy\n   + uploads objects" {
  style.stroke: "#f59e0b"
  style.stroke-width: 2
}

bucket -> objects: "contains" {
  style.stroke: "#f59e0b"
}

objects -> public: "4. s3:GetObject\n   Principal: \"*\"\n   no auth required" {
  style.stroke: "#3b82f6"
  style.stroke-width: 2
}

reqs -> bucket: "satisfies" {
  style.stroke: "#10b981"
  style.stroke-width: 2
  style.stroke-dash: 4
}
